{
  // Extends the config generated by `quasar prepare` (.quasar/tsconfig.json),
  // which wires Quasar's path aliases (src/*, components, #q-app, …) and types.
  "extends": "./.quasar/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true
  }
}
